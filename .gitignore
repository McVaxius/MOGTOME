## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
build/
bld/
[Bb]in/
[Oo]bj/

# Visual Studio 2015 cache/options directory
.vs/

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NuGet Packages
*.nupkg
**/packages/*

# Rider
.idea/

# Learning/Documentation files (not for end users)
*.md
!README.md
!CHANGELOG.md

# Backup files
backup/

# User configuration (contains personal settings)
**/pluginConfigs/MOGTOME.json

# Dalamud dev files
*.pdb
*.dll.config
